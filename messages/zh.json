    "overviewBody": "ToxicPaw \u4f7f\u7528\u7b97\u6cd5\u8bc4\u5206\u7cfb\u7edf\u5206\u6790\u5ba0\u7269\u7cae\u6210\u5206\u8868\u3002\u6211\u4eec\u7684\u76ee\u6807\u662f\u4e3a\u5ba0\u7269\u4e3b\u4eba\u63d0\u4f9b\u4e00\u4e2a\u6613\u7528\u3001\u900f\u660e\u7684\u5de5\u5177\u6765\u7406\u89e3\u6210\u5206\u7ec4\u6210\u3002\u672c\u9875\u8be6\u7ec6\u8bb0\u5f55\u4e86\u6211\u4eec\u7684\u8bc4\u5206\u65b9\u6cd5\uff0c\u4ee5\u4fbf\u72ec\u7acb\u8bc4\u4f30\u3002",
    "dataSourcesTitle": "\u6570\u636e\u6765\u6e90",
    "dataSourcesBody": "\u6211\u4eec\u7684\u6210\u5206\u6570\u636e\u5e93\u5305\u542b 500+ \u6761\u76ee\uff0c\u53c2\u8003\u4ee5\u4e0b\u6765\u6e90\uff1a\n\n\u2022 AAFCO\uff08\u7f8e\u56fd\u996e\u6599\u7ba1\u7406\u5b98\u5458\u534f\u4f1a\uff09\u6210\u5206\u5b9a\u4e49\u548c\u6307\u5357\n\u2022 FDA \u517d\u533b\u4e2d\u5fc3\u5ba0\u7269\u98df\u54c1\u5b89\u5168\u6307\u5357\n\u2022 \u5df2\u53d1\u8868\u7684\u517d\u533b\u8425\u517b\u5b66\u6587\u732e\n\u2022 \u516c\u5f00\u53ef\u7528\u7684\u6210\u5206\u5b89\u5168\u6570\u636e\n\n\u6bcf\u79cd\u6210\u5206\u88ab\u5206\u914d\u4e00\u4e2a\u5b89\u5168\u7b49\u7ea7\uff08\u5b89\u5168\u3001\u8c28\u614e\u3001\u6709\u5bb3\uff09\u548c\u4e00\u4e2a\u5206\u7c7b\uff08\u5982\u86cb\u767d\u8d28\u3001\u8c37\u7269\u3001\u586b\u5145\u5242\u3001\u526f\u4ea7\u54c1\u3001\u8272\u7d20\u3001\u751c\u5473\u5242\uff09\u3002\u8fd9\u4e9b\u5206\u7c7b\u53cd\u6620\u7684\u662f\u4e00\u822c\u6027\u8425\u517b\u89c2\u70b9\uff0c\u5e76\u975e\u76d1\u7ba1\u5224\u5b9a\u3002",
    "howScoringWorksTitle": "\u8bc4\u5206\u6d41\u7a0b",
    "howScoringWorksBody": "\u5f53\u60a8\u626b\u63cf\u6216\u641c\u7d22\u5ba0\u7269\u7cae\u65f6\uff0c\u6211\u4eec\u7684\u7cfb\u7edf\u4f1a\uff1a\n\n1. \u89e3\u6790\u6210\u5206\u8868\u5e76\u6807\u51c6\u5316\u6bcf\u4e2a\u6210\u5206\u540d\u79f0\n2. \u5728\u6570\u636e\u5e93\u4e2d\u67e5\u627e\u6bcf\u4e2a\u6210\u5206\uff08\u7cbe\u786e\u5339\u914d\u3001\u522b\u540d\u5339\u914d\u6216\u6a21\u7cca\u5339\u914d\uff09\n3. \u4e3a\u6bcf\u4e2a\u6210\u5206\u5206\u914d\u6807\u8bb0\uff1a\u7eff\u8272\uff08\u5b89\u5168\uff09\u3001\u9ec4\u8272\uff08\u8c28\u614e\uff09\u3001\u7ea2\u8272\uff08\u6709\u5bb3\uff09\u3001\u7070\u8272\uff08\u672a\u77e5/\u4e0d\u5728\u6570\u636e\u5e93\u4e2d\uff09\n4. \u8ba1\u7b97 0 \u5230 100 \u7684\u6570\u5b57\u5206\u6570\n5. \u5c06\u5206\u6570\u6620\u5c04\u4e3a\u5b57\u6bcd\u7b49\u7ea7\uff08A \u5230 F\uff09\n6. \u751f\u6210\u7b80\u660e\u7684\u8bc4\u4ef7",
    "ingredientCategoriesTitle": "\u6210\u5206\u5206\u7c7b",
    "ingredientCategoriesBody": "\u6570\u636e\u5e93\u4e2d\u6bcf\u79cd\u6210\u5206\u5c5e\u4e8e 17 \u4e2a\u5206\u7c7b\u4e4b\u4e00\uff1a\u86cb\u767d\u8d28\u3001\u8c37\u7269\u3001\u84d4\u83dc\u3001\u6c34\u679c\u3001\u8102\u80aa/\u6cb9\u3001\u7ea4\u7ef4\u3001\u7ef4\u751f\u7d20\u3001\u77ff\u7269\u8d28\u3001\u9632\u8150\u5242\u3001\u6dfb\u52a0\u5242\u3001\u751c\u5473\u5242\u3001\u8272\u7d20\u3001\u586b\u5145\u5242\u3001\u526f\u4ea7\u54c1\u3001\u8425\u517b\u8865\u5145\u5242\u3001\u589e\u7a20\u5242\u3001\u8c03\u5473\u5242\u3002\n\n\u67d0\u4e9b\u5206\u7c7b\u65e0\u8bba\u5176\u4e2a\u4f53\u5b89\u5168\u7b49\u7ea7\u5982\u4f55\uff0c\u90fd\u88ab\u89c6\u4e3a\u201c\u503c\u5f97\u5173\u6ce8\u201d\u3002\u8fd9\u4e9b\u5206\u7c7b\u5305\u62ec\uff1a\u586b\u5145\u5242\u3001\u526f\u4ea7\u54c1\u3001\u8272\u7d20\u548c\u751c\u5473\u5242\u3002\u5c5e\u4e8e\u8fd9\u4e9b\u5206\u7c7b\u7684\u6210\u5206\u5373\u4f7f\u88ab\u5355\u72ec\u8bc4\u4e3a\u5b89\u5168\uff0c\u4e5f\u4f1a\u989d\u5916\u6263\u5206\uff0c\u56e0\u4e3a\u5b83\u4eec\u7684\u5b58\u5728\u53ef\u80fd\u8868\u660e\u6574\u4f53\u914d\u65b9\u8d28\u91cf\u8f83\u4f4e\u3002",
    "scoringRulesTitle": "\u8bc4\u5206\u89c4\u5219",
    "scoringRulesBody": "\u5206\u6570\u4ece 100 \u5f00\u59cb\uff0c\u6309\u4ee5\u4e0b\u89c4\u5219\u8c03\u6574\uff1a\n\n\u2022 \u6bcf\u4e2a\u6709\u5bb3\uff08\u7ea2\u8272\uff09\u6210\u5206\uff1a\u221215 \u5206\n\u2022 \u5728\u524d 5 \u4f4d\u7684\u6709\u5bb3\u6210\u5206\uff1a\u989d\u5916 \u22125 \u5206\n\u2022 \u6bcf\u4e2a\u8c28\u614e\uff08\u9ec4\u8272\uff09\u6210\u5206\uff1a\u22125 \u5206\n\u2022 \u5728\u524d 5 \u4f4d\u7684\u8c28\u614e\u6210\u5206\uff1a\u989d\u5916 \u22123 \u5206\n\u2022 \u6bcf\u4e2a\u5c5e\u4e8e\u5173\u6ce8\u5206\u7c7b\u7684\u6210\u5206\uff08\u586b\u5145\u5242\u3001\u526f\u4ea7\u54c1\u3001\u8272\u7d20\u3001\u751c\u5473\u5242\uff09\uff1a\u22123 \u5206\n\u2022 \u52a0\u5206\uff1a\u7b2c\u4e00\u4e2a\u6210\u5206\u662f\u4f18\u8d28\u86cb\u767d\u8d28\u6765\u6e90\uff1a+5 \u5206\n\u2022 \u6263\u5206\uff1a\u524d 3 \u4e2a\u6210\u5206\u4e2d\u6ca1\u6709\u86cb\u767d\u8d28\u6765\u6e90\uff1a\u221210 \u5206\n\n\u6210\u5206\u4f4d\u7f6e\u5f88\u91cd\u8981\uff0c\u56e0\u4e3a\u5ba0\u7269\u98df\u54c1\u6cd5\u89c4\u8981\u6c42\u6210\u5206\u6309\u91cd\u91cf\u964d\u5e8f\u6392\u5217\u3002\u524d\u51e0\u4f4d\u7684\u6210\u5206\u5360\u98df\u54c1\u7684\u6700\u5927\u6bd4\u4f8b\u3002\n\n\u6700\u7ec8\u5206\u6570\u9650\u5236\u5728 0\u2013100 \u8303\u56f4\u5185\u3002",
    "gradeThresholdsTitle": "\u7b49\u7ea7\u5212\u5206",
    "gradeThresholdsBody": "\u6570\u5b57\u5206\u6570\u5bf9\u5e94\u5b57\u6bcd\u7b49\u7ea7\uff1a\n\n\u2022 A\uff1a90\u2013100\uff08\u4f18\u79c0\uff09\n\u2022 B\uff1a75\u201389\uff08\u826f\u597d\uff09\n\u2022 C\uff1a60\u201374\uff08\u4e00\u822c\uff09\n\u2022 D\uff1a40\u201359\uff08\u8f83\u5dee\uff09\n\u2022 F\uff1a0\u201339\uff08\u5f88\u5dee\uff09\n\n\u8fd9\u4e9b\u9608\u503c\u5728\u7b97\u6cd5\u4e2d\u56fa\u5b9a\uff0c\u5bf9\u6240\u6709\u4ea7\u54c1\u4e00\u81f4\u9002\u7528\u3002",
    "petProfileTitle": "\u5ba0\u7269\u6863\u6848\u8c03\u6574",
    "petProfileBody": "\u5f53\u7528\u6237\u63d0\u4f9b\u5ba0\u7269\u7684\u54c1\u79cd\u3001\u5e74\u9f84\u3001\u4f53\u91cd\u6216\u5065\u5eb7\u72b6\u51b5\u65f6\uff0c\u7cfb\u7edf\u4f1a\u8fdb\u884c\u989d\u5916\u7684\u5206\u6570\u8c03\u6574\u3002\u4f8b\u5982\uff0c\u5bf9\u4e8e\u5df2\u77e5\u9e21\u8089\u8fc7\u654f\u7684\u5ba0\u7269\uff0c\u542b\u6709\u9e21\u8089\u7684\u98df\u54c1\u53ef\u80fd\u4f1a\u88ab\u989d\u5916\u6263\u5206\u3002\u8fd9\u4e9b\u8c03\u6574\u5728\u57fa\u7840\u5206\u6570\u4e4b\u4e0a\u8fdb\u884c\uff0c\u7ed3\u679c\u4ecd\u7136\u9650\u5236\u5728 0\u2013100 \u8303\u56f4\u5185\u3002",
    "whatWeDoNotEvaluateTitle": "\u6211\u4eec\u4e0d\u8bc4\u4f30\u7684\u5185\u5bb9",
    "whatWeDoNotEvaluateBody": "\u6211\u4eec\u7684\u5206\u6790\u4ec5\u9650\u4e8e\u6210\u5206\u7ec4\u6210\u3002\u6211\u4eec\u4e0d\u8bc4\u4f30\uff1a\n\n\u2022 \u751f\u4ea7\u8d28\u91cf\u548c\u5de5\u827a\u6d41\u7a0b\n\u2022 \u751f\u7269\u5229\u7528\u5ea6\u548c\u6d88\u5316\u7387\n\u2022 \u6279\u6b21\u95f4\u4e00\u81f4\u6027\n\u2022 \u76d1\u7ba1\u5408\u89c4\u5386\u53f2\n\u2022 \u4e2a\u4f53\u5ba0\u7269\u5065\u5eb7\u72b6\u51b5\uff08\u9664\u975e\u63d0\u4f9b\u5ba0\u7269\u6863\u6848\uff09\n\u2022 \u54c1\u79cd\u7279\u5b9a\u8425\u517b\u9700\u6c42\uff08\u9664\u975e\u63d0\u4f9b\u5ba0\u7269\u6863\u6848\uff09\n\u2022 \u70ed\u91cf\u5bc6\u5ea6\u6216\u4fdd\u8bc1\u5206\u6790\u503c\n\u2022 \u53ec\u56de\u5386\u53f2",
    "limitationsTitle": "\u5c40\u9650\u6027",
    "limitationsBody": "\u89e3\u8bfb\u7ed3\u679c\u65f6\u8bf7\u8003\u8651\u4ee5\u4e0b\u51e0\u70b9\uff1a\n\n\u2022 \u6211\u4eec\u7684\u6570\u636e\u5e93\u53ef\u80fd\u672a\u5305\u542b\u6bcf\u79cd\u6210\u5206\u3002\u672a\u8bc6\u522b\u7684\u6210\u5206\u6807\u8bb0\u4e3a\u201c\u672a\u77e5\u201d\uff0c\u4e0d\u4f1a\u5bf9\u5206\u6570\u4ea7\u751f\u6b63\u9762\u6216\u8d1f\u9762\u5f71\u54cd\u3002\n\u2022 \u6210\u5206\u5b89\u5168\u6027\u53d6\u51b3\u4e8e\u4e0a\u4e0b\u6587\u3002\u5242\u91cf\u3001\u7269\u79cd\u548c\u4e2a\u4f53\u5065\u5eb7\u90fd\u5f88\u91cd\u8981\u3002\n\u2022 \u8bb8\u591a\u88ab\u6807\u8bb0\u7684\u6210\u5206\u5df2\u83b7 FDA/AAFCO \u6279\u51c6\uff0c\u5728\u89c4\u5b9a\u7528\u91cf\u4e0b\u662f\u5b89\u5168\u7684\u3002\u6807\u8bb0\u53cd\u6620\u7684\u662f\u7b97\u6cd5\u5206\u7c7b\uff0c\u800c\u975e\u786e\u5b9a\u6027\u7684\u5b89\u5168\u5224\u65ad\u3002\n\u2022 \u672c\u5de5\u5177\u662f\u517d\u533b\u6307\u5bfc\u7684\u8865\u5145\uff0c\u800c\u975e\u66ff\u4ee3\u3002\n\u2022 \u57fa\u4e8e OCR \u7684\u626b\u63cf\u53ef\u80fd\u5728\u6210\u5206\u6587\u5b57\u8bc6\u522b\u4e2d\u5f15\u5165\u8bef\u5dee\u3002",
    "openToFeedbackTitle": "\u6b22\u8fce\u53cd\u9988",
    "openToFeedbackBody": "\u6211\u4eec\u529b\u6c42\u51c6\u786e\u548c\u900f\u660e\u3002\u5982\u679c\u60a8\u662f\u54c1\u724c\u4ee3\u8868\u3001\u517d\u533b\u4e13\u4e1a\u4eba\u58eb\u6216\u7814\u7a76\u4eba\u5458\uff0c\u5e76\u8ba4\u4e3a\u6211\u4eec\u7684\u5206\u6790\u5b58\u5728\u9519\u8bef\u6216\u53ef\u4ee5\u6539\u8fdb\uff0c\u6211\u4eec\u6b22\u8fce\u60a8\u7684\u53cd\u9988\u3002\u8bf7\u8054\u7cfb feedback@toxicpaw.com\u3002\u6211\u4eec\u81f4\u529b\u4e8e\u6839\u636e\u53ef\u4fe1\u8bc1\u636e\u66f4\u65b0\u6211\u4eec\u7684\u6570\u636e\u5e93\u3002"
  }
}
